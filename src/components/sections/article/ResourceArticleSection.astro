---
import Breadcrumb from "../../Breadcrumb.astro";
import ArticleCard from "../../ArticleCard.astro";
import TopicCard from "../../TopicCard.astro";
const { breadcrumbItems, commercialMaterial, content, article, tArticle, lang } = Astro.props;
const basePath = lang === 'en' ? '/en' : '';
const withLang = (path) => `${basePath}${path}`;

---
<section class="mb-16 md:mb-[124px] min-h-[calc(80vh-88px)]">
    <div class="container">
        <div class="pt-6 pb-5">
            <Breadcrumb items={breadcrumbItems} />
        </div>
        <div class="articles">
            <div class="heading mb-5">
                <h2 class="text-xl text-brand-700 font-aghato font-medium mb-4">{tArticle.content.articleFeatured}</h2>
            </div>
            {article.article?.length > 0 ? (
                <div class="grid grid-cols-1 md:grid-cols-3 auto-rows-min mb-8 gap-y-6 gap-x-8">
                    {article.article.map((item) => (
                        <ArticleCard
                                class=""
                                title={item.title}
                                link={item.url}
                        />
                    ))}
                </div>
            ) : (
                <p class="text-sm text-gray-400 my-20">
                    No hay material disponible por el momento.
                </p>
            )}
            <!--
            <hr class="border-gray-200 mb-8">
            <div class="cards-topics grid grid-cols-1 md:grid-cols-3 auto-rows-min gap-y-6 gap-x-8">
                <TopicCard title="Material comercial" items={commercialMaterial} href={withLang("/faena-tulum/material-comercial/")} />
                <TopicCard title="Contenido" items={content} href={withLang("/faena-tulum/contenido" )}/>
            </div>
            -->
        </div>
    </div>
</section>