---
import Image from "astro/components/Image.astro";
import brokerImage from "../../assets/images/broken/broker-rodrigo-setien.webp";

const { t, lang, developmentName } = Astro.props;
const KEY_GOOGLE = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY;
const siteTag = '';
---

<section id="sectionForm" class="section-form mt-16">
    <div class="w-full px-5 mx-auto sm:max-w-[540px] md:max-w-[720px] lg:max-w-[960px] xl:max-w-[1140px] 2xl:max-w-[1320px]">
        <div class="flex flex-wrap -mx-3">
            <div class="w-full lg:w-10/12 mx-auto px-3">
                <div class="flex flex-wrap -mx-3 md:pl-1">

                    <!-- BROKER COLUMN -->
                    <div class="w-full lg:w-5/12 px-3">
                        <div class="broker-container lg:flex lg:justify-start">
                            <div class="broker-person relative">
                                <div class="photo-broker">
                                    <div class="photo-broker__background">
                                        <Image src={brokerImage} alt="Rodrigo Setién" class="broker-img" />
                                    </div>
                                </div>
                                <div class="bottom-contact">
                                    <h3>{t['broker_name']}</h3>
                                    <p>{t['broker_occupation']}</p>
                                    <div class="spacer-top"></div>
                                    <a class="broker-cta" href={`tel:${t['broker_phone_number']}`}>
                                        <span class="hidden lg:inline-block pe-1">{t['broker_phone']}</span>
                                        <span>{t['broker_phone_display']}</span>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- FORM COLUMN -->
                    <div class="w-full lg:w-7/12 px-3">
                        <div class="heading-form">
                            <span>{t['form_subtitle']}</span>
                            <h2>{t['form_title']}</h2>
                            <p>{t['form_description']}</p>
                        </div>
                        <form id="contactForm" method="POST" class="space-y-4" novalidate>
                            <!-- NAME -->
                            <input type="hidden" name="tag" id="siteTag" value={siteTag} />

                            <div class="flex flex-col gap-4 lg:flex-row">
                               <div class="flex-1">
                                   <input type="text" name="name" id="name" required placeholder="Nombre"
                                          class="w-full border border-gray-300 rounded-lg px-4 py-3"/>
                                   <p class="text-red-500 text-sm mt-1 hidden" id="nameError">
                                       El nombre es obligatorio.
                                   </p>
                               </div>
                                <div class="flex-1">
                                   <input type="text" name="lastname" id="lastname" required placeholder="Apellido"
                                          class="w-full border border-gray-300 rounded-lg px-4 py-3"/>
                                   <p class="text-red-500 text-sm mt-1 hidden" id="lastnameError">
                                       El apellido es obligatorio.
                                   </p>
                               </div>
                            </div>

                            <!-- EMAIL + PHONE -->
                            <div class="flex flex-col gap-4 lg:flex-row">
                                <div class="flex-1">
                                    <input type="email" name="email" id="email" required placeholder="Correo electrónico"
                                           class="w-full border border-gray-300 rounded-lg px-4 py-3"/>
                                    <p class="text-red-500 text-sm mt-1 hidden" id="emailError">
                                        Ingresa un correo electrónico válido.
                                    </p>
                                </div>
                                <div class="flex-1">
                                    <input type="tel" name="phone" id="phone" required placeholder="Número telefónico"
                                           class="w-full border border-gray-300 rounded-lg px-4 py-3"/>
                                    <p class="text-red-500 text-sm mt-1 hidden" id="phoneError">
                                        El número telefónico es obligatorio.
                                    </p>
                                </div>
                            </div>

                            <!-- MESSAGE -->
                            <div>
                            <textarea name="message" id="message" rows="4" required placeholder="Escribe aquí tu mensaje"
                                      class="w-full border border-gray-300 rounded-lg px-4 py-3"></textarea>
                                <p class="text-red-500 text-sm mt-1 hidden" id="messageError">
                                    El mensaje es obligatorio.
                                </p>
                            </div>

                            <!-- BUTTON + MESSAGES -->
                            <div>
                                <button type="submit" id="submitBtn" class="flex items-center justify-center w-[175px] h-[44px] px-4 py-3 gap-2 bg-brand-400 text-white text-sm font-medium rounded-[100px] transition duration-300 hover:opacity-90">
                                    Send Request
                                </button>
                                <div>
                                    <p id="formSuccess" class="hidden text-green-600 mt-2">¡Mensaje enviado correctamente!</p>
                                    <p id="formError" class="hidden text-red-600 mt-2">Hubo un error, intenta de nuevo.</p>
                                    <p id="formRateLimit" class="hidden text-red-600 mt-2">Has alcanzado el límite de envíos. Intenta de nuevo más tarde.</p>
                                </div>
                                <p class="text-xs text-gray-400 mt-4">
                                    Este sitio está protegido por reCAPTCHA. Aplican la
                                    <a href="https://policies.google.com/privacy" target="_blank" class="underline">Política de Privacidad</a>
                                    y los
                                    <a href="https://policies.google.com/terms" target="_blank" class="underline">Términos de Servicio</a>
                                    de Google.
                                </p>
                            </div>

                        </form>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>
<script>

</script>
<!-- reCAPTCHA: cargar script con tu site key -->
<script src={`https://www.google.com/recaptcha/api.js?render=${KEY_GOOGLE}`}></script>

<script define:vars={{ KEY_GOOGLE }}>
    window.addEventListener("load", () => {

        // Ocultar badge
        const badge = document.querySelector(".grecaptcha-badge");
        if (badge) {
            badge.style.setProperty("visibility", "hidden", "important");
            badge.style.setProperty("opacity", "0", "important");
            badge.style.setProperty("width", "0", "important");
            badge.style.setProperty("height", "0", "important");
        }

        const form = document.getElementById("contactForm");
        if (!form) return;

        const successEl = document.getElementById("formSuccess");
        const errorEl = document.getElementById("formError");
        const submitBtn = document.getElementById("submitBtn");
        const rateLimitEl = document.getElementById("formRateLimit");

        const fields = [
            { input: form.name, error: document.getElementById("nameError") },
            { input: form.lastname, error: document.getElementById("lastnameError") },
            { input: form.email, error: document.getElementById("emailError"), validator: val => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val) },
            { input: form.phone, error: document.getElementById("phoneError") },
            { input: form.message, error: document.getElementById("messageError") },
        ];

        fields.forEach(f => {
            f.input.addEventListener("input", () => {
                if (f.input.value.trim() && (!f.validator || f.validator(f.input.value))) {
                    f.error.classList.add("hidden");
                }
            });
        });

        form.addEventListener("submit", async (e) => {
            e.preventDefault();

            let isValid = true;
            fields.forEach(f => {
                if (!f.input.value.trim() || (f.validator && !f.validator(f.input.value))) {
                    f.error.classList.remove("hidden");
                    isValid = false;
                } else {
                    f.error.classList.add("hidden");
                }
            });

            if (!isValid) return;

            successEl?.classList.add("hidden");
            errorEl?.classList.add("hidden");
            rateLimitEl?.classList.add("hidden");

            submitBtn.disabled = true;
            submitBtn.textContent = "Verificando...";

            try {
                // grecaptcha.ready garantiza que reCAPTCHA esté completamente cargado
                const recaptchaToken = await new Promise((resolve, reject) => {
                    grecaptcha.ready(async () => {
                        try {
                            const token = await grecaptcha.execute(KEY_GOOGLE, { action: "contact_form" });
                            resolve(token);
                        } catch (err) {
                            reject(err);
                        }
                    });
                });

                const response = await fetch("https://kearealtors.com/api/submit-contact", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        name: form.name.value,
                        lastname: form.lastname.value,
                        email: form.email.value,
                        phone: form.phone.value,
                        message: form.message.value,
                        tag: form.tag.value,
                        recaptchaToken,
                    }),
                });

                if (response.status === 429) {
                    rateLimitEl.textContent = "Has alcanzado el límite de envíos. Intenta de nuevo más tarde.";
                    rateLimitEl?.classList.remove("hidden");
                    return;
                }

                let data = null;
                try { data = await response.json(); } catch {}

                if (response.ok && data?.success) {
                    form.reset();
                    successEl?.classList.remove("hidden");
                } else if (data?.error) {
                    errorEl.textContent = "Hubo un error, intenta de nuevo o mas tarde.";
                    errorEl?.classList.remove("hidden");
                } else {
                    errorEl.textContent = "Hubo un error, intenta de nuevo.";
                    errorEl?.classList.remove("hidden");
                }

            } catch (err) {
                errorEl.textContent = "Hubo un error, intenta de nuevo.";
                errorEl?.classList.remove("hidden");
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = "Send Request";
            }
        });
    });
</script>

