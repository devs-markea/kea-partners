<style>
/* Contact Form Section */
.section-form {
    margin-bottom: 126px;
    }

.broker-person {
    display: flex;
    flex-direction: row;
    align-items: end;
    }

.broker-person .photo-broker {
    width: 150px;
    position: absolute;
    z-index: 1;
    }

.photo-broker__background {
    position: relative;
    top: 4px;
    }

.photo-broker__background::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    right: 0;
    left: 0;
    background: #F7F4F0;
    z-index: -1;
    margin-right: 2rem;
    margin-top: 2rem;
    margin-bottom: 4px;
    border-radius: 16px 16px 0 8px;
    }

.heading-form {
    margin-top: 32px;
    margin-bottom: 24px;
    }

.heading-form span {
    color: var(--secondary-900);
    font-weight: 400;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 5%;
    margin-bottom: 4px;
    }

.heading-form h2 {
    font-family: var(--font-secondary), sans-serif;
    font-size: 28px;
    font-weight: 700;
    letter-spacing: 5%;
    color: var(--neutral-900);
    margin-bottom: 16px;
    }

.heading-form p {
    font-size: 16px;
    font-weight: 300;
    letter-spacing: 5%;
    color: var(--neutral-900);
    line-height: 24px;
    }

.bottom-contact {
    display: flex;
    flex-direction: column;
    align-items: start;
    padding: 4px 16px 4px 148px;
    border-radius: 0 8px 8px 8px;
    position: relative;
    background-color: #FFF;
    width: 100%;
    margin-right: 0;
    }

.bottom-contact:before {
    content: '';
    position: absolute;
    top: 0;
    bottom: -4px;
    left: 0;
    right: 0;
    background-color: var(--secondary-900);
    z-index: -1;
    box-shadow: 0 0 8px var(--neutral-300);
    border-radius: 0 8px 8px 8px;
    }

.broker-person .bottom-contact h3 {
    font-family: var(--font-secondary), sans-serif;
    font-size: 20px;
    font-weight: 700;
    line-height: 32px;
    color: var(--neutral-900);
    margin-bottom: 4px;
    }

.broker-person .bottom-contact p {
    font-size: 14px;
    font-weight: 400;
    line-height: 20px;
    color: var(--neutral-900);
    margin-bottom: 4px;
    }

.broker-person .bottom-contact .spacer-top {
    width: 100%;
    height: 1px;
    background-color: var(--neutral-300);
    margin-bottom: 4px;
    }

.broker-person .bottom-contact .broker-cta {
