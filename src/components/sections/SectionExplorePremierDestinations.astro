---
import TopDestinationCard from "../TopDestinationCard.astro";


const { t, lang } = Astro.props;

const basePath = lang === "en" ? "/en" : "";
const withLang = (path) => `${basePath}/${path}`;

const images = import.meta.glob(
    "/src/assets/images/destinations/*.webp",
    { eager: true }
);

const destinations = [...t.highlights_destinations].sort((a, b) =>
    a.destination_title.localeCompare(b.destination_title, undefined, {
        sensitivity: "base",
        numeric: true
    })
);


---

<section class="section-highlights pt-11 md:pt-16">
    <div class="highlights container mx-auto px-5 md:px-8">

        <div class="flex justify-center">
            <div class="w-full">

                <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-12 ">
                    <h2 class="title">
                        {t.highlights_title}
                    </h2>

                    <div class="subtitle mt-2 md:mt-0">
                        {t.highlights_subtitle}
                    </div>
                </div>

                <!-- Content -->
                <div class="destinations">
                    <div class="swiper">
                        <div class="swiper-wrapper">
                            {destinations.map((destination, index) => {
                                const imagePath = `/src/assets/images/destinations/${destination.destination_img}.webp`;
                                const imageModule = images[imagePath];
                                const image = imageModule?.default;

                                if (!image) {
                                    console.error("Imagen no encontrada:", imagePath);
                                    return null;
                                }

                                return (
                                        <div class="swiper-slide w-auto">
                                            <TopDestinationCard
                                                    src={image}
                                                    alt={destination.destination_title}
                                                    title={destination.destination_title}
                                                    subtitle={destination.destination_description}
                                                    url={withLang(destination.destination_url)}
                                                    priority={index === 0}
                                            />
                                        </div>
                                );
                            })}
                        </div>

                        <div class="swiper-pagination-destinations mt-8 flex justify-center"></div>
                    </div>
                </div>

            </div>
        </div>

    </div>
</section>

<script>
    import Swiper from 'swiper';
    import { Navigation, Pagination, Autoplay } from 'swiper/modules';
    import 'swiper/css';
    import 'swiper/css/pagination';
    import 'swiper/css/navigation';

    function swiperDestinations() {
        const el = document.querySelector('.destinations .swiper');
        if (!el) return;

        new Swiper(el, {
            modules: [Navigation, Pagination, Autoplay],

            slidesPerView: 1,
            spaceBetween: 20,
            centerInsufficientSlides: true,

            breakpoints: {
                320: { slidesPerView: 1, spaceBetween: 15 },
                768: { slidesPerView: 2, spaceBetween: 20 },
                1024: { slidesPerView: 3, spaceBetween: 30 }
            },

            pagination: {
                el: '.swiper-pagination-destinations',
                clickable: true,
                type: 'bullets'
            },

            navigation: true,
            grabCursor: true,
            speed: 500,

            keyboard: {
                enabled: true,
                onlyInViewport: true
            },

            mousewheel: {
                forceToAxis: true
            },

            on: {
                init() {
                    this.el.classList.add('swiper-loaded');
                },
                slideChange() {
                    document.dispatchEvent(
                        new CustomEvent('swiperSlideChange', {
                            detail: {
                                activeIndex: this.activeIndex,
                                slides: this.slides.length
                            }
                        })
                    );
                }
            }
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', swiperDestinations);
    } else {
        swiperDestinations();
    }
</script>

