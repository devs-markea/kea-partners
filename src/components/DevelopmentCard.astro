---
import { Image } from "astro:assets";
import { images } from "../assets/images";

interface Props {
    link: string;
    src: keyof typeof images;
    alt: string;
    hasPadding?: boolean;
    hasZoom?: boolean;
}

const {
    src,
    alt,
    link,
    hasPadding = true,
    hasZoom = false,
} = Astro.props;

const imgSrc = images[src];

if (!imgSrc) {
    throw new Error(`Image key "${src}" not found in images map`);
}
---

<div class="w-full min-w-0 h-[180px] grid place-items-center border border-gray-200 rounded-xl overflow-hidden">
    <a
            href={link}
            class={`grid place-items-center w-full h-full ${
                hasPadding ? "p-10" : ""
            }`}
    >
        <Image
                class={`max-w-full max-h-full object-contain ${
                    hasZoom ? "scale-125" : ""
                }`}
                src={imgSrc}
                alt={alt}
                quality={90}
                loading="eager"
        />
    </a>
</div>