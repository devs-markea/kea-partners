---
import { Image } from "astro:assets";
const {title, subtitle, url, src, alt} = Astro.props;

---
<div class="top-destination">
    <Image
            src={src}
            alt={alt}
            loading="lazy"
    />
    <div class="content">
        <a href={`/destinations${url}`}>
            <div class="float-card">
                <div class="heading">
                    <h3>{ title }</h3>
                </div>
                <div class="paragraph">
                    <p>{ subtitle }</p>
                </div>
            </div>
        </a>

    </div>
</div>
