---
import MainLayout from '../layouts/MainLayout.astro';
import es from '../locales/es.json';
import SvgIcon from "../components/SvgIcon.astro";
import {Image} from "astro:assets";
import { images } from "../assets/images";
import FaqItem from "../components/FaqItem.astro";
import Search from "../components/Search.astro";

const lang = "es";
---

<MainLayout title="Home" lang={lang} t={es}>
    <!-- Hero -->
    <section class="bg-brand-400 py-16 md:py-24">
        <div class="container mx-auto flex flex-col items-center">
            <div class="flex flex-col items-center text-center md:w-7/12">
                <h1  class="text-[32px] text-brand-50 font-aghato font-medium mb-8 md:text-5xl">{es.site.description}</h1>
                <div class="search mb-5 w-10/12 md:w-7/12">
                    <Search/>
                </div>
                <div class="introduction md:ml-[44px]">
                    <p class="text-brand-50">Encuentra todo lo necesario para promocionar nuestros desarrollos: brochures, artes, disponibilidades y más.</p>
                </div>
            </div>
        </div>
    </section>
    <!-- Developments -->
    <section class="pt-11 pb-16 md:pt-16 md:pb-20">
        <div class="container mx-auto flex flex-col items-start">
            <div class="development-heading mb-4">
                <h2 class="text-[32px] text-brand-700 font-aghato font-medium m-0">Desarrollos</h2>
            </div>
            <div class="development-paragraph mb-6">
                <p class="text-brand-700 font-normal">Selecciona el desarrollo de tu interés para acceder a todos los recursos disponibles: fichas técnicas, precios, brochures, contenido para redes y más.</p>
            </div>
            <div class="developments-cards flex justify-start items-stretch flex-wrap gap-4">
                <div class="flex items-center justify-center border border-gray-200  rounded-xl basis-[calc(50%-0.5rem)] md:basis-[calc(16.666%-0.5rem)] min-h-[150px]">
                    <a href="/faena-tulum">
                        <Image class="w-1/2 h-auto m-auto" src={images.Faena} alt="Faena Tulum" quality={90}  loading="eager"/>
                    </a>
                </div>
