---
import {Image} from "astro:assets";
import { images } from "../../../assets/images";
import MainLayout from "../../../layouts/MainLayout.astro";
import ArticleCard from "../../../components/ArticleCard.astro";
import TopicsMenu from "../../../components/TopicsMenu.astro";
import PdfViewer from "../../../components/PDFViewer.astro";
import es from '../../../locales/es.json';
import Breadcrumb from "../../../components/Breadcrumb.astro";
import HeroArticleSection from "../../../components/sections/article/HeroArticleSection.astro";
import ResourcesBrochuresSection
    from "../../../components/sections/faena-tulum/material-comercial/ResourcesBrochuresSection.astro";
import Data from "../../../data/i18n/es/faena-tulum.json";

const breadcrumbItems = [
    { name: 'Categorias', url: '/' },
    { name: 'Faena Tulum', url: '/faena-tulum' },
    { name: 'Material Comercial', url: '/faena-tulum/material-comercial' },
    { name: 'Brochure digitales y descargables' },
];
---
<MainLayout title="Home" lang="es" t={es} >
    <!-- Hero -->
    <HeroArticleSection t={Data} lang="es"/>
    <ResourcesBrochuresSection breadcrumbItems = {breadcrumbItems} lang="es"/>
</MainLayout>