---
import MainLayout from '../../layouts/MainLayout.astro';
import home from '../../data/i18n/en/home.json';
import common from '../../data/i18n/en/common.json';
import SvgIcon from "../../components/SvgIcon.astro";
import {Image} from "astro:assets";
import { images } from "../../assets/images";
import Search from "../../components/Search.astro";
import DevelopmentCard2 from "../../components/DevelopmentCard2.astro";
import HeroSection from "../../components/sections/HeroSection.astro";
import HighEndResortLivingSection from "../../components/sections/HighEndResortLivingSection.astro";
import FaqSection from "../../components/sections/FaqSection.astro";
import BannerHelperSection from "../../components/sections/BannerHelperSection.astro";
import BrandedResidencesSection from "../../components/sections/BrandedResidencesSection.astro";

const lang = "en";
---

<MainLayout title="Home" lang={lang} t={common}>
    <!-- Hero -->
    <HeroSection t={home}/>
    <!-- Resont Branded Resedents  -->
    <BrandedResidencesSection t={home} lang="en"/>
    <!-- Developments -->
    <HighEndResortLivingSection t={home} lang="en"/>
    <!-- FAQs -->
   <FaqSection t={home}/>
    <!-- Banner -->
    <BannerHelperSection t={home}>
</MainLayout>