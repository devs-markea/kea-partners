---
import {Image} from "astro:assets";
import { images } from "../../../../assets/images";
import MainLayout from "../../../../layouts/MainLayout.astro";
import en from '../../../../locales/en.json';
import HeroArticleSection from "../../../../components/sections/article/HeroArticleSection.astro";
import ResourcesBrochuresSection
    from "../../../../components/sections/faena-tulum/material-comercial/ResourcesBrochuresSection.astro";
import Breadcrumb from "../../../../components/Breadcrumb.astro";
import Data from "../../../../data/i18n/es/faena-tulum.json";

const breadcrumbItems = [
    { name: 'Category', url: '/en/' },
    { name: 'Faena Tulum', url: '/en/faena-tulum' },
    { name: 'Commercial Material', url: '/en/faena-tulum/material-comercial' },
    { name: 'Digital and Downloadable Brochures' },
];
---
<MainLayout title="Home" lang="en" t={en}>
    <!-- Hero -->
    <HeroArticleSection t={Data} lang="en"/>
    <ResourcesBrochuresSection breadcrumbItems = {breadcrumbItems} lang="en"/>
</MainLayout>