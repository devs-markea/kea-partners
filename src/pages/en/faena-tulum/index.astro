---
import {Image} from "astro:assets";
import { images } from "../../../assets/images";
import MainLayout from "../../../layouts/MainLayout.astro";
import common from '../../../data/i18n/en/common.json';
import article from '../../../data/i18n/en/article.json';
import Breadcrumb from "../../../components/Breadcrumb.astro";
import ArticleCard from "../../../components/ArticleCard.astro";
import TopicCard from "../../../components/TopicCard.astro";
import HeroArticleSection from "../../../components/sections/article/HeroArticleSection.astro";
import ResourceArticleSection
    from "../../../components/sections/article/ResourceArticleSection.astro";

const breadcrumbItems = [
    { name: 'Category', url: '/en/' },
    { name: 'Faena Tulum' } // última, sin link
];

const commercialMaterial = [
    "Brochure",
    "Renders",
    "Siteplan",
];
const content = [
    "Kit esencial para redes sociales"
];
---
<MainLayout title="Home" lang="en" t={common}>
    <!-- Hero -->
    <HeroArticleSection />
    <ResourceArticleSection breadcrumbItems = {breadcrumbItems} commercialMaterial = {commercialMaterial} content = {content} t={article} lang="en"/>
</MainLayout>