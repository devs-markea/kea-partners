-->
    <a href={resolveUrl(t.nav.faq.url)} class="block text-[2rem] font-light text-black">
        {t.nav.faq.label}
    </a>

    <a href={resolveUrl(t.nav.contact.url)} class="block text-[2rem] font-light text-black">
        {t.nav.contact.label}
    </a>
</div>
