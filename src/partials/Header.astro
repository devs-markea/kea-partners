        >
            {t.nav.category.label}
            <svg class="submenu-icon w-6 h-6 text-brand-400 transition-transform duration-200 mr-6" stroke="currentColor" viewBox="0 0 16 16" fill="none">
                <path d="M13 5.5L8 10.5L3 5.5" stroke="#053F47" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </button>

        <div class="submenu-container max-h-0 overflow-hidden opacity-0 transition-all duration-300 ease-in-out pl-6 space-y-1">
            <a href={resolveUrl("/faena-tulum")} class="block text-[1.75rem] font-light text-gray-700 text-opacity-60">Faena Tulum</a>
            <a href={resolveUrl("/st-regis")} class="block text-[1.75rem] font-light text-gray-700 text-opacity-60">St. Regis</a>
            <a href={resolveUrl("/nautica")} class="block text-[1.75rem] font-light text-gray-700 text-opacity-60">Nautica Residences</a>
            <a href={resolveUrl("/marietta")} class="block text-[1.75rem] font-light text-gray-700 text-opacity-60">Marietta</a>
            <a href={resolveUrl("/mayaliah")} class="block text-[1.75rem] font-light text-gray-700 text-opacity-60">Mayaliah</a>
            <a href={resolveUrl("/gran-via-del-mar")} class="block text-[1.75rem] font-light text-gray-700 text-opacity-60">Gran Vía del Mar</a>
