---
import SvgIcon from "../components/SvgIcon.astro";
import { images } from "../assets/images";
import { Image } from "astro:assets";

const { lang, t } = Astro.props;

/**
 * REAL project convention:
 * - Spanish → /
 * - English → /en
 */
const basePath = lang === "en" ? "/en" : "";

/**
 * Normalize paths and avoid // or /en//
 */
const resolveUrl = (url) =>
    `${basePath}${url}`.replace(/\/{2,}/g, "/");

/**
 * Language switch (if enabled later)
 */
const switchLang = lang === "es" ? "en" : "es";
const switchLangUrl = lang === "es" ? "/en" : "/";
---
<!-- Overlay -->
<div id="overlay" class="fixed inset-0 bg-black bg-opacity-50 hidden"></div>

<header class="bg-brand-400 text-brand-50 shadow-md sticky top-0 z-40">
    <div class="container mx-auto flex justify-between items-center py-4 px-6">

        <!-- Logo -->
        <div class="flex items-center justify-center md:gap-5">
            <a href={basePath || "/"}>
                <Image
                        class="w-[86px] md:w-[100px] h-auto"
                        src={images.Logo}
                        alt="Kea Realtors"
                        quality={90}
                        loading="eager"
                />
            </a>
            <p class="text-base font-medium tracking-[10%] m-0 hidden md:block">
                {t.nav.title.toUpperCase()}
            </p>
        </div>

        <!-- Desktop Nav -->
        <nav class="hidden md:block">
            <ul class="flex gap-6 text-brand-50">
                <li>
                    <a
                        href={resolveUrl(t.nav.home.url)}
                        class="tracking-[10%] hover:text-white hover:opacity-80 transition-opacity"
                    >
                        {t.nav.home.label}
                    </a>
                </li>

                <!--  <li>
                    <a href={"/" + resolveUrl(t.nav.category.url)} class="hover:text-blue-600 tracking-[10%]">
                        {t.nav.category.label}
                    </a>
                </li>-->

                <li>
                    <a
                        href={resolveUrl(t.nav.home.url)}
                        class="tracking-[10%] hover:text-white hover:opacity-80 transition-opacity"
                    >
                        {t.nav.faq.label}
                    </a>
                </li>

                <li>
                    <a
                            href={resolveUrl(t.nav.contact.url)}
                            class="px-5 py-2 bg-brand-300 rounded-[2rem] hover:bg-opacity-90 transition-colors duration-300 text-center font-normal tracking-[10%] uppercase"
                    >
                        {t.nav.contact.label}
                    </a>
                </li>
            </ul>
        </nav>

        <!-- Mobile Button -->
        <button class="block md:hidden" id="menu-toggle">
            <SvgIcon iconKey="HamburgerIcon" width={34} height={34} />
        </button>

    </div>
</header>

<!-- Mobile Menu -->
<div
        id="side-menu"
        class="fixed inset-y-0 left-0 w-[90%] max-w-sm bg-brand-50 transform -translate-x-full transition-transform duration-200 ease-in-out z-50 p-6 space-y-4 md:hidden"
>
    <div class="w-full flex justify-end">
        <button id="close-menu" class="p-2 rounded-md text-gray-700 hover:bg-gray-100">
            <svg class="w-5 h-5 text-black" stroke="currentColor" viewBox="0 0 20 20" fill="none">
                <path d="M1 1L19 19" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M1 19L19 1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </button>
    </div>

    <a href={resolveUrl(t.nav.home.url)} class="block text-[2rem] font-normal text-black">
        {t.nav.home.label}
    </a>

   <!--  <div>
        <button
